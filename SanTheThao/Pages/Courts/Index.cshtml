@page
@model SanTheThao.Pages.Courts.IndexModel
@{
    ViewData["Title"] = "Danh sách sân";
    Layout = "_Layout";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="fw-bold mb-0">
        @if (Model.SelectedSport != null)
        {
            <span>@Model.SelectedSport.Icon @Model.SelectedSport.Name</span>
        }
        else
        {
            <span>🏟️ Tất cả sân</span>
        }
    </h4>
    <span class="text-muted small">@Model.Courts.Count sân</span>
</div>

<!-- Filter môn -->
<div class="d-flex flex-wrap gap-2 mb-4">
    <a asp-page="/Courts/Index"
       class="btn btn-sm @(Model.SportTypeId == null ? "btn-primary" : "btn-outline-secondary")">
        Tất cả
    </a>
    @foreach (var sport in Model.SportTypes)
    {
        <a asp-page="/Courts/Index" asp-route-sportTypeId="@sport.Id"
           class="btn btn-sm @(Model.SportTypeId == sport.Id ? "btn-primary" : "btn-outline-secondary")">
            @sport.Icon @sport.Name
        </a>
    }
</div>

@if (!Model.Courts.Any())
{
    <div class="text-center py-5 text-muted">
        <div style="font-size:3rem">🏟️</div>
        <p class="mt-2">Không có sân nào</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var court in Model.Courts)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm court-card">
                    <!-- Ảnh sân -->
                    <div style="height:180px;overflow:hidden;border-radius:12px 12px 0 0;background:#f3f4f6">
                        @if (!string.IsNullOrEmpty(court.ImageUrl))
                        {
                            <img src="@court.ImageUrl" alt="@court.Name"
                                 style="width:100%;height:100%;object-fit:cover;transition:transform 0.4s ease" class="court-img" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100"
                                 style="background:linear-gradient(135deg,#e0e7ff,#c7d2fe)">
                                <span style="font-size:4rem">@court.SportType.Icon</span>
                            </div>
                        }
                    </div>

                    <div class="card-body">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <span class="badge bg-primary small">@court.SportType.Name</span>
                        </div>
                        <h6 class="fw-bold mb-1">@court.Name</h6>
                        @if (!string.IsNullOrEmpty(court.Description))
                        {
                            <p class="text-muted small mb-2">@court.Description</p>
                        }
                        <div class="fw-bold text-success">
                            @court.PricePerHour.ToString("N0") VNĐ / giờ
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0">
                        <a asp-page="/Courts/Detail" asp-route-id="@court.Id" class="btn btn-primary w-100 fw-semibold btn-sm">
                            Xem lịch & Đặt sân
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

}

<style>
    .court-card:hover .court-img {
        transform: scale(1.06);
    }
</style>
