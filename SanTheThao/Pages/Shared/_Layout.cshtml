                <div class="col-lg-4">
                    <div class="footer-heading">Liên hệ</div>
                    <div class="footer-contact-item">
                        <a href="https://maps.app.goo.gl/3wyLtqvH5DHUPUdN8" target="_blank" class="footer-link">
                        📍<span>Dong Anh, Ha Noi, Vietnam</span></a>
                    </div>
                    <div class="footer-contact-item">📞 <a href="tel:0901234567" class="footer-link">0901 234 567</a></div>
                    <div class="footer-contact-item">✉️ <a href="mailto:contact@santhethao.com" class="footer-link">contact@santhethao.com</a></div>
                    <div class="footer-contact-item">🕐 <span>Mở cửa 06:00 – 22:00 hàng ngày</span></div>
                </div>

                <div class="footer-bottom">
                    <span>© 2025 Sân Thể Thao. All rights reserved.</span>
                    <span>Made with ❤️ in Việt Nam</span>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <script>
        // Scroll reveal
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) {
                    e.target.style.opacity = '1';
                    e.target.style.transform = 'translateY(0)';
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal').forEach(el => {
            el.style.opacity = '0';
            el.style.transform = 'translateY(30px)';
            el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
            observer.observe(el);
        });

        // Navbar scroll effect
        window.addEventListener('scroll', () => {
            const nav = document.querySelector('.navbar');
            if (window.scrollY > 50) {
                nav.style.background = 'rgba(15,23,42,0.98)';
            } else {
                nav.style.background = 'rgba(15,23,42,0.92)';
            }
        });



        // =========================================================================
        // LOGIC FETCH API ĐIỀU KHIỂN KHUNG CHAT POPUP (GROQ / LLAMA 3.1)
        // =========================================================================
        document.addEventListener("DOMContentLoaded", function () {
            const navLink = document.getElementById("navChatbotLink");
            const closeBtn = document.getElementById("closeChatbotBtn");
            const popup = document.getElementById("chatbotPopup");
            const input = document.getElementById("chatbotInput");
            const sendBtn = document.getElementById("chatbotSendBtn");
            const body = document.getElementById("chatbotBody");

            // 1. Đóng/Mở khung chat bằng nút trên Navbar
            navLink.addEventListener("click", function () {
                if (popup.style.display === "none" || popup.style.display === "") {
                    popup.style.display = "flex";
                    input.focus();
                } else {
                    popup.style.display = "none";
                }
            });

            // 2. Đóng khung chat bằng nút dấu X
            closeBtn.addEventListener("click", function () {
                popup.style.display = "none";
            });

            // 3. Hàm xử lý gửi tin nhắn sang API Backend (.cshtml.cs)
            async function sendMessage() {
                const messageText = input.value.trim();
                if (!messageText) return;

                // Hiển thị tin nhắn của User lên giao diện
                appendMessage(messageText, "user");
                input.value = "";

                // Hiển thị trạng thái Bot đang xử lý
                const loadingId = appendMessage("Đang suy nghĩ...", "bot");

                try {
                    // Bắn dữ liệu lên Handler OnPostAsync của file chatbot.cshtml.cs
                    const response = await fetch('/api/chatbot', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ Message: messageText })
                    });

                    if (response.ok) {
                        const data = await response.json();
                        // Xóa dòng loading cũ và hiển thị chữ chuẩn bốc từ Llama 3.1
                        removeMessage(loadingId);
                        appendMessage(data.reply, "bot");
                    } else {
                        removeMessage(loadingId);
                        appendMessage("Bot: Hix, hệ thống gặp sự cố kết nối rồi.", "bot");
                    }
                } catch (error) {
                    removeMessage(loadingId);
                    appendMessage("Bot: Không thể kết nối đến Backend server.", "bot");
                }
            }

            // Hỗ trợ bấm nút Gửi hoặc nhấn phím Enter để chat
            sendBtn.addEventListener("click", sendMessage);
            input.addEventListener("keypress", function (e) {
                if (e.key === "Enter") {
                    sendMessage();
                }
            });

            // Hàm phụ trợ tạo các bong bóng tin nhắn
            function appendMessage(text, sender) {
                const msgId = "msg-" + Date.now();
                const msgDiv = document.createElement("div");
                msgDiv.id = msgId;
                msgDiv.classList.add("chat-msg", sender);
                msgDiv.innerText = text;
                body.appendChild(msgDiv);
                body.scrollTop = body.scrollHeight; // Tự cuộn màn hình xuống cuối
                return msgId;
            }

            function removeMessage(id) {
                const el = document.getElementById(id);
                if (el) el.remove();
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>