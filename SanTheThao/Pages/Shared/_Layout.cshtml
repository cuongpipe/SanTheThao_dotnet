<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Sân Thể Thao</title>
    <link rel="icon" type="image/x-icon" href="~/images/logo/santhethao.logo.png">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
    <style>

    </style>
<body>

    <!=============== header ================-->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-page="/Index">
                <img src="~/images/logo/santhethao.logo.png" style="width:35px; height:35px; border-radius:8px" alt="Sân Thể Thao">
                <span>Sân <span style="color:var(--p1, #22c55e)">Thể Thao</span></span>
            </a>
            
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav me-auto gap-1">
                    <li class="nav-item"><a class="nav-link" asp-page="/Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/Courts/Index">Đặt sân</a></li>
                    <li class="nav-item"><a class="nav-link" asp-page="/News/Index">Tin tức</a></li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item"><a class="nav-link" asp-page="/Booking/MyBookings">Lịch sử</a></li>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">⚙️ Admin</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-page="/Admin/Dashboard">📊 Dashboard</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-page="/Admin/Bookings">📋 Quản lý đơn</a></li>
                                <li><a class="dropdown-item" asp-page="/Admin/Courts">🏟️ Quản lý sân</a></li>
                                <li><a class="dropdown-item" asp-page="/Admin/Users">👥 Tài khoản</a></li>
                                <li><a class="dropdown-item" asp-page="/Admin/News">📰 Tin tức</a></li>
                            </ul>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link fw-bold text-success" href="javascript:void(0);" id="navChatbotLink">🤖 Trợ lý AI</a>
                    </li>
                </ul>

                <form method="get" asp-page="/Courts/Search" class="d-flex me-2 nav-search-form">
                    <div class="input-group input-group-sm">
                        <input type="text" name="search" class="form-control nav-search-input"
                            placeholder="🔍 Tìm tên sân..." value="@(Context.Request.Query["search"].ToString())"
                            autocomplete="off" />
                        <button class="btn btn-primary btn-sm nav-search-btn" type="submit">Tìm</button>
                    </div>
                </form>

                <ul class="navbar-nav ms-auto align-items-center gap-1">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
                                <div class="nav-avatar">@User.Identity.Name?.Substring(0,1).ToUpper()</div>
                                <span class="d-none d-md-inline">@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li class="px-3 py-2 border-bottom" style="border-color:rgba(255,255,255,0.1)!important">
                                    <div class="text-white fw-semibold small">@User.Identity.Name</div>
                                    <div style="color:rgba(255,255,255,0.4);font-size:0.75rem">@(User.IsInRole("Admin") ? "Quản trị viên" : "Thành viên")</div>
                                </li>
                                <li><a class="dropdown-item mt-1" asp-page="/Account/Profile">👤 Thông tin cá nhân</a></li>
                                <li><a class="dropdown-item" asp-page="/Booking/MyBookings">📋 Lịch sử đặt sân</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" style="color:#f87171" asp-page="/Auth/Logout">🚪 Đăng xuất</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-page="/Auth/Login">Đăng nhập</a></li>
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm px-3 fw-semibold" asp-page="/Auth/Register">Đăng ký</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>





    <div class="container py-4">
        @RenderBody()
    </div>




<!=============== chatbot popup ================-->
    <div id="chatbotPopup" class="chatbot-popup">
        <div class="chatbot-header">
            <div style="display: flex; align-items: center; gap: 8px;">
                <span style="font-size: 1.2rem;">🤖</span>
                <div>
                    <div style="font-weight: 700; font-size: 0.9rem;">Trợ lý ảo thông minh</div>
                    <div style="font-size: 0.7rem; color: #cbd5e1;">Online | Tư vấn tự động</div>
                </div>
            </div>
            <span id="closeChatbotBtn" style="cursor: pointer; font-size: 1.5rem; font-weight: bold; line-height: 1;">&times;</span>
        </div>
        
        <div id="chatbotBody" class="chatbot-body">
            <div class="chat-msg bot">
                Xin chào! Tôi là Trợ lý AI. Tôi đã đồng bộ với hệ thống dữ liệu sân bãi. Bạn cần hỏi gì về danh sách sân hay thông tin hoạt động không ạ? 🏟️
            </div>
        </div>

        <div class="chatbot-footer">
            <input type="text" id="chatbotInput" placeholder="Nhập tin nhắn..." autocomplete="off">
            <button id="chatbotSendBtn">Gửi</button>
        </div>
    </div>


<!=============== foooter ================-->
    <footer class="site-footer">
