                        Sân <span>Thể Thao</span>
                    </div>
                    <p style="color:rgba(255,255,255,0.45);font-size:0.875rem;line-height:1.8;max-width:280px">
                        Hệ thống đặt sân thể thao trực tuyến — nhanh chóng, tiện lợi và uy tín.
                    </p>
                    <div class="d-flex gap-2 mt-3">
                        <a href="https://www.facebook.com/people/S%C3%A2n-Th%E1%BB%83-Thao/61590934222984/" class="social-btn text-decoration-none" title="Facebook">
                            <i class="bi bi-facebook" style="color: #1877F2; font-size: 1.3rem;"></i>
                        </a>
                        <a href="https://www.instagram.com/santhethao/" class="social-btn text-decoration-none" title="Instagram">
                            <i class="bi bi-instagram" style="color: #E4405F; font-size: 1.3rem;"></i>
                        </a>
                        <a href="https://www.tiktok.com/santhethao" class="social-btn text-decoration-none" title="TikTok">
                            <i class="bi bi-tiktok" style="color: #000000; font-size: 1.3rem;"></i>
                        </a>
                        <a href="https://www.youtube.com/santhethao" class="social-btn text-decoration-none" title="YouTube">
                            <i class="bi bi-youtube" style="color: #FF0000; font-size: 1.3rem;"></i>
                        </a>
                    </div>
                </div>

                <div class="col-6 col-lg-2">
                    <div class="footer-heading">Đặt sân</div>
                    <div class="d-flex flex-column">
                        <a asp-page="/Courts/Index" asp-route-sportTypeId="1" class="footer-link">⚽ Bóng đá</a>
                        <a asp-page="/Courts/Index" asp-route-sportTypeId="2" class="footer-link">🏸 Cầu lông</a>
                        <a asp-page="/Courts/Index" asp-route-sportTypeId="3" class="footer-link">🏐 Bóng chuyền</a>
                        <a asp-page="/Courts/Index" asp-route-sportTypeId="4" class="footer-link">🏀 Bóng rổ</a>
                        <a asp-page="/Courts/Index" asp-route-sportTypeId="5" class="footer-link">🎾 Pickleball</a>
                    </div>
                </div>

                <div class="col-6 col-lg-2">
                    <div class="footer-heading">Hỗ trợ</div>
                    <div class="d-flex flex-column">
                        <a asp-page="/News/Index" class="footer-link">Tin tức</a>
                        <a asp-page="/Auth/Register" class="footer-link">Đăng ký</a>
                        <a asp-page="/Auth/Login" class="footer-link">Đăng nhập</a>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-page="/Booking/MyBookings" class="footer-link">Lịch sử đặt</a>
                            <a asp-page="/Account/Profile" class="footer-link">Tài khoản</a>
