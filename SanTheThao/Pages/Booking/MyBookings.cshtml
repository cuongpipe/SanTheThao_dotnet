@page
@model SanTheThao.Pages.Booking.MyBookingsModel
@using SanTheThao.Models
@{
    ViewData["Title"] = "Lịch sử đặt sân";
    Layout = "_Layout";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-bold mb-0">📋 Lịch sử đặt sân</h4>
    <a asp-page="/Courts/Index" class="btn btn-primary btn-sm">+ Đặt sân mới</a>
</div>

@if (TempData["Message"] != null)
{
    var isError = TempData["IsError"] as bool? ?? false;
    <div class="alert @(isError ? "alert-danger" : "alert-success") py-2">
        @TempData["Message"]
    </div>
}

@if (!Model.Bookings.Any())
{
    <div class="text-center py-5">
        <div style="font-size:4rem">🏟️</div>
        <h5 class="mt-3 text-muted">Bạn chưa có đơn đặt sân nào</h5>
        <a asp-page="/Courts/Index" class="btn btn-primary mt-3">Đặt sân ngay</a>
    </div>
}
else
{
    <!-- Filter theo trạng thái -->
    <div class="d-flex gap-2 mb-3 flex-wrap">
        @{
            var all       = Model.Bookings.Count;
            var pending   = Model.Bookings.Count(b => b.Status == BookingStatus.Pending);
            var confirmed = Model.Bookings.Count(b => b.Status == BookingStatus.Confirmed);
            var cancelled = Model.Bookings.Count(b => b.Status == BookingStatus.Cancelled);
        }
        <span class="badge bg-secondary fs-6 fw-normal px-3 py-2">Tất cả (@all)</span>
        <span class="badge bg-warning text-dark fs-6 fw-normal px-3 py-2">Chờ xác nhận (@pending)</span>
        <span class="badge bg-success fs-6 fw-normal px-3 py-2">Đã xác nhận (@confirmed)</span>
        <span class="badge bg-danger fs-6 fw-normal px-3 py-2">Đã hủy (@cancelled)</span>
    </div>

    <!-- Danh sách đơn -->
    <div class="d-flex flex-column gap-3">
        @foreach (var booking in Model.Bookings)
        {
            var statusClass = booking.Status switch
            {
                BookingStatus.Pending   => "warning",
                BookingStatus.Confirmed => "success",
                BookingStatus.Cancelled => "danger",
                _ => "secondary"
            };
            var statusText = booking.Status switch
            {
                BookingStatus.Pending   => "Chờ xác nhận",
                BookingStatus.Confirmed => "Đã xác nhận",
                BookingStatus.Cancelled => "Đã hủy",
                _ => ""
            };

            <div class="card border-0 shadow-sm @(booking.Status == BookingStatus.Cancelled ? "opacity-75" : "")">
                <div class="card-body">
                    <div class="row align-items-center">

                        <!-- Icon + tên sân -->
                        <div class="col-md-4">
                            <div class="d-flex align-items-center gap-2">
                                <span style="font-size:2rem">@booking.Court.SportType.Icon</span>
                                <div>
                                    <div class="fw-bold">@booking.Court.Name</div>
                                    <div class="text-muted small">@booking.Court.SportType.Name</div>
                                </div>
                            </div>
                        </div>

                        <!-- Ngày giờ -->
                        <div class="col-md-3 mt-2 mt-md-0">
                            <div class="fw-semibold">
                                @booking.BookingDate.ToString("dd/MM/yyyy")
                            </div>
                            <div class="text-muted small">
                                @booking.StartTime.ToString("HH:mm") - @booking.EndTime.ToString("HH:mm")
                            </div>
                        </div>

                        <!-- Giá + trạng thái -->
                        <div class="col-md-3 mt-2 mt-md-0">
                            <div class="fw-bold text-success">
                                @booking.TotalPrice.ToString("N0") VNĐ
                            </div>
                            <span class="badge bg-@statusClass">@statusText</span>
                        </div>

                        <!-- Nút hủy -->
                        <div class="col-md-2 mt-2 mt-md-0 text-md-end">
                            <div class="text-muted small mb-1">#@booking.Id.ToString("D6")</div>
                            @if (booking.Status == BookingStatus.Pending)
                            {
                                <form method="post" asp-page-handler="Cancel"
                                      onsubmit="return confirm('Bạn có chắc muốn hủy đơn này không?')">
                                    <input type="hidden" name="bookingId" value="@booking.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Hủy</button>
                                </form>
                            }
                        </div>

                    </div>

                    @if (!string.IsNullOrEmpty(booking.Note))
                    {
                        <div class="mt-2 pt-2 border-top small text-muted">
                            📝 @booking.Note
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
