@page
@model SanTheThao.Pages.Booking.MyBookingsModel
@using SanTheThao.Models
@{
    ViewData["Title"] = "Lịch sử đặt sân";
    Layout = "_Layout";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-bold mb-0">📋 Lịch sử đặt sân</h4>
    <a asp-page="/Courts/Index" class="btn btn-primary btn-sm">+ Đặt sân mới</a>
</div>

@if (TempData["Message"] != null)
{
    var isError = TempData["IsError"] as bool? ?? false;
    <div class="alert @(isError ? "alert-danger" : "alert-success") py-2">
        @TempData["Message"]
    </div>
}

@if (!Model.Bookings.Any())
{
    <div class="text-center py-5">
        <div style="font-size:4rem">🏟️</div>
        <h5 class="mt-3 text-muted">Bạn chưa có đơn đặt sân nào</h5>
        <a asp-page="/Courts/Index" class="btn btn-primary mt-3">Đặt sân ngay</a>
    </div>
}
else
{
    <div class="d-flex gap-1 mb-4 border-bottom status-filter-container">
        @{
            var all       = Model.Bookings.Count;
            var pending   = Model.Bookings.Count(b => b.Status == BookingStatus.Pending);
            var confirmed = Model.Bookings.Count(b => b.Status == BookingStatus.Confirmed);
            var cancelled = Model.Bookings.Count(b => b.Status == BookingStatus.Cancelled);
        }
        <button class="btn-filter active" data-filter="all">Tất cả (@all)</button>
        <button class="btn-filter" data-filter="pending">Chờ xác nhận (@pending)</button>
        <button class="btn-filter" data-filter="confirmed">Đã xác nhận (@confirmed)</button>
        <button class="btn-filter" data-filter="cancelled">Đã hủy (@cancelled)</button>
    </div>

    <div class="d-flex flex-column gap-3">
        @foreach (var booking in Model.Bookings)
        {
            var statusClass = booking.Status switch
            {
                BookingStatus.Pending   => "warning",
                BookingStatus.Confirmed => "success",
                BookingStatus.Cancelled => "danger",
                _ => "secondary"
            };
            var statusText = booking.Status switch
            {
                BookingStatus.Pending   => "Chờ xác nhận",
                BookingStatus.Confirmed => "Đã xác nhận",
                BookingStatus.Cancelled => "Đã hủy",
                _ => ""
            };

            <div class="card border-0 shadow-sm booking-item @(booking.Status == BookingStatus.Cancelled ? "opacity-75" : "")"
                 data-status="@booking.Status.ToString().ToLower()">
                <div class="card-body">
                    <div class="row align-items-center">

                        <div class="col-md-4">
                            <div class="d-flex align-items-center gap-2">
                                <span style="font-size:2rem">@booking.Court.SportType.Icon</span>
                                <div>
                                    <div class="fw-bold">@booking.Court.Name</div>
                                    <div class="text-muted small">@booking.Court.SportType.Name</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3 mt-2 mt-md-0">
                            <div class="fw-semibold">
                                @booking.BookingDate.ToString("dd/MM/yyyy")
                            </div>
                            <div class="text-muted small">
                                @booking.StartTime.ToString("HH:mm") - @booking.EndTime.ToString("HH:mm")
                            </div>
                        </div>

                        <div class="col-md-3 mt-2 mt-md-0">
                            <div class="fw-bold text-success">
                                @booking.TotalPrice.ToString("N0") VNĐ
                            </div>
                            <span class="badge bg-@statusClass">@statusText</span>
                        </div>

                        <div class="col-md-2 mt-2 mt-md-0 text-md-end">
                            <div class="text-muted small mb-1">#@booking.Id.ToString("D6")</div>
                            @if (booking.Status == BookingStatus.Pending)
                            {
                                <form method="post" asp-page-handler="Cancel"
                                      onsubmit="return confirm('Bạn có chắc muốn hủy đơn này không?')">
                                    <input type="hidden" name="bookingId" value="@booking.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Hủy</button>
                                </form>
                            }
                        </div>

                    </div>

                    @if (!string.IsNullOrEmpty(booking.Note))
                    {
                        <div class="mt-2 pt-2 border-top small text-muted">
                            📝 @booking.Note
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

<style>
    /* Thanh bọc cuộn ngang nếu màn hình điện thoại bị thiếu chỗ */
    .status-filter-container {
        overflow-x: auto;
        white-space: nowrap;
    }
    
    /* Nút bấm mặc định: Không viền, nền trong suốt */
    .btn-filter {
        background: transparent;
        border: none;
        padding: 10px 15px;
        color: var(--dark3);
    }
    
    /* Khi rê chuột hoặc khi được Active: Đổi chữ sang màu xanh và gạch chân đơn giản */
    .btn-filter:hover, .btn-filter.active {
        color: var(--p1);
        text-decoration: underline;
        font-weight: bold;
    }
</style>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const filters = document.querySelectorAll(".btn-filter");
            const bookingItems = document.querySelectorAll(".booking-item");

            filters.forEach(filter => {
                filter.addEventListener("click", function () {
                    // 1. Chuyển đổi class active giữa các nút tab
                    filters.forEach(btn => btn.classList.remove("active"));
                    this.classList.add("active");

                    // 2. Lấy giá trị bộ lọc (all, pending, confirmed, cancelled)
                    const filterValue = this.getAttribute("data-filter");

                    // 3. Thực hiện ẩn/hiện card mà không cần tải lại trang
                    bookingItems.forEach(item => {
                        const itemStatus = item.getAttribute("data-status");

                        if (filterValue === "all" || itemStatus === filterValue) {
                            item.style.setProperty('display', 'block', 'important');
                        } else {
                            item.style.setProperty('display', 'none', 'important');
                        }
                    });
                });
            });
        });
    </script>
}