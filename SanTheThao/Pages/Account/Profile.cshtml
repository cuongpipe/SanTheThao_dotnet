@page
@model SanTheThao.Pages.Account.ProfileModel
@{
    ViewData["Title"] = "Thông tin cá nhân";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-lg-7">

        <h4 class="fw-bold mb-4">👤 Thông tin cá nhân</h4>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success py-2">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger py-2">@TempData["Error"]</div>
        }

        <!-- Thông tin cá nhân -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h6 class="fw-bold mb-3">📝 Thông tin tài khoản</h6>
                <form method="post" asp-page-handler="Update">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input type="text" class="form-control bg-light" value="@Model.Input.Email" readonly />
                        <div class="form-text">Email không thể thay đổi</div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.FullName" class="form-label fw-semibold">Họ và tên</label>
                        <input asp-for="Input.FullName" class="form-control" />
                        <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Input.PhoneNumber" class="form-label fw-semibold">Số điện thoại</label>
                        <input asp-for="Input.PhoneNumber" class="form-control" />
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-primary fw-semibold">Lưu thay đổi</button>
                </form>
            </div>
        </div>

        <!-- Đổi mật khẩu -->
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="fw-bold mb-3">🔒 Đổi mật khẩu</h6>
                <form method="post" asp-page-handler="Password">
                    <div class="mb-3">
                        <label asp-for="PasswordChange.CurrentPassword" class="form-label fw-semibold">Mật khẩu hiện tại</label>
                        <input asp-for="PasswordChange.CurrentPassword" type="password" class="form-control" placeholder="••••••••" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="PasswordChange.NewPassword" class="form-label fw-semibold">Mật khẩu mới</label>
                        <input asp-for="PasswordChange.NewPassword" type="password" class="form-control" placeholder="Tối thiểu 6 ký tự" />
                        <span asp-validation-for="PasswordChange.NewPassword" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="PasswordChange.ConfirmPassword" class="form-label fw-semibold">Xác nhận mật khẩu mới</label>
                        <input asp-for="PasswordChange.ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu mới" />
                        <span asp-validation-for="PasswordChange.ConfirmPassword" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-warning fw-semibold">Đổi mật khẩu</button>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
